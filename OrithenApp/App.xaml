<Application x:Class="OrithenApp.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
  <Application.Resources>
    <SolidColorBrush x:Key="AccentBrush" Color="#4F46E5" />
    <SolidColorBrush x:Key="AccentDarkBrush" Color="#3730A3" />
    <SolidColorBrush x:Key="BackgroundBrush" Color="#F8FAFC" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="BorderBrush" Color="#D7E2F2" />
    <SolidColorBrush x:Key="TextBrush" Color="#1E293B" />

    <Style TargetType="Button">
      <Setter Property="Background" Value="#4F46E5" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="Padding" Value="12,8" />
      <Setter Property="BorderBrush" Value="#4338CA" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <Style TargetType="TextBox">
      <Setter Property="Padding" Value="8" />
      <Setter Property="BorderBrush" Value="#C7D2FE" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Background" Value="White" />
    </Style>

    <Style TargetType="ComboBox">
      <Setter Property="Padding" Value="8" />
      <Setter Property="BorderBrush" Value="#C7D2FE" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Background" Value="White" />
    </Style>

    <Style TargetType="ListBox">
      <Setter Property="Background" Value="White" />
      <Setter Property="BorderBrush" Value="#D7E2F2" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
  </Application.Resources>
</Application>
