<Page x:Class="OrithenApp.Views.CreateTemplatePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Crear plantilla">
  <ScrollViewer>
    <StackPanel Margin="10">
      <TextBlock Text="Nombre de la sesión" FontWeight="Bold" />
      <TextBox x:Name="SessionNameBox" Margin="0,0,0,8" />

      <TextBlock Text="Calentamiento" FontWeight="Bold" Margin="0,10,0,0" />
      <TextBox x:Name="WarmupBox" Margin="0,0,0,8" />

      <TextBlock Text="Bloque principal" FontWeight="Bold" Margin="0,10,0,0" />
      <TextBox x:Name="BlockNameBox" Margin="0,0,0,8" />

      <TextBlock Text="Estación 1" FontWeight="Bold" Margin="0,10,0,0" />
      <TextBox x:Name="Station1Box" Margin="0,0,0,8" />

      <TextBlock Text="Estación 2" FontWeight="Bold" Margin="0,10,0,0" />
      <TextBox x:Name="Station2Box" Margin="0,0,0,8" />

      <Button Content="Guardar plantilla" Click="SaveTemplate" Margin="0,10,0,0" />
    </StackPanel>
  </ScrollViewer>
</Page>
