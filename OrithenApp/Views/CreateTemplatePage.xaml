<Page x:Class="OrithenApp.Views.CreateTemplatePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Crear plantilla">
  <ScrollViewer>
    <StackPanel Margin="10">
      <TextBlock Text="Programa" FontWeight="Bold" />
      <ComboBox x:Name="ProgramComboBox" Margin="0,0,0,8" />

      <TextBlock Text="Escalfament" FontWeight="Bold" Margin="0,10,0,0" />
      <StackPanel x:Name="WarmupCheckBoxes" Margin="0,0,0,8" />

      <TextBlock Text="Metodologia" FontWeight="Bold" Margin="0,10,0,0" />
      <ComboBox x:Name="MethodologyComboBox" Margin="0,0,0,8" />

      <StackPanel x:Name="BlocksPanel" Margin="0,8,0,0" />

      <Button Content="+" Click="AddBlock" Width="30" Height="30" Margin="0,0,0,8" />
      <Button Content="Guardar plantilla" Click="SaveTemplate" Margin="0,10,0,0" />
    </StackPanel>
  </ScrollViewer>
</Page>
