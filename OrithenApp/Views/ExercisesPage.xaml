<Page x:Class="OrithenApp.Views.ExercisesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Gestión de ejercicios">
  <Page.Resources>
    <DataTemplate x:Key="ExerciseItemTemplate">
      <Grid Margin="0,4">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <TextBlock Text="{Binding DisplayText}" VerticalAlignment="Center" />
        <Button Grid.Column="1" Content="Eliminar" Background="Red" Foreground="White" Margin="8,0,0,0" Click="DeleteExercise" Tag="{Binding Id}" />
      </Grid>
    </DataTemplate>
  </Page.Resources>

  <Grid Margin="4" Background="#F8FAFC">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="360" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <Border Margin="0,0,12,0" Padding="16" Background="#FFFFFF" BorderBrush="#D7E2F2" BorderThickness="1" CornerRadius="10">
      <StackPanel>
        <TextBlock Text="Introduir dades" FontSize="20" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,0,12" />

        <TextBlock Text="Seleccionar tipus" FontWeight="SemiBold" Margin="0,0,0,4" />
        <ComboBox x:Name="CategoryComboBox" Margin="0,0,0,10">
          <ComboBoxItem Content="Programa" />
          <ComboBoxItem Content="Escalfament" />
          <ComboBoxItem Content="Metodologia" />
          <ComboBoxItem Content="Repeticions" />
          <ComboBoxItem Content="Exercicis" />
        </ComboBox>

        <TextBlock Text="Descripció" FontWeight="SemiBold" Margin="0,0,0,4" />
        <TextBox x:Name="TypeBox" Margin="0,0,0,12" />

        <StackPanel Orientation="Horizontal">
          <Button Content="Guardar" Click="AddExercise" Margin="0,0,8,0" />
        </StackPanel>
      </StackPanel>
    </Border>

    <Border Grid.Column="1" Padding="16" Background="#FFFFFF" BorderBrush="#D7E2F2" BorderThickness="1" CornerRadius="10">
      <DockPanel>
        <TextBlock Text="Dades" FontSize="18" FontWeight="SemiBold" Foreground="#1E293B" DockPanel.Dock="Top" Margin="0,0,0,8" />
        <TabControl x:Name="CategoryTabs" />
      </DockPanel>
    </Border>
  </Grid>
</Page>
