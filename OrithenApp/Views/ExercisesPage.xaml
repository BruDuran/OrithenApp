<Page x:Class="OrithenApp.Views.ExercisesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Gestión de ejercicios">
  <Grid Margin="10">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
      <TextBox x:Name="NameBox" Width="180" Margin="0,0,8,0" />
      <TextBox x:Name="CategoryBox" Width="120" Margin="0,0,8,0" />
      <TextBox x:Name="MaterialBox" Width="120" Margin="0,0,8,0" />
      <Button Content="Añadir" Click="AddExercise" />
    </StackPanel>

    <ListBox x:Name="ExercisesList" Grid.Row="1" />
  </Grid>
</Page>
