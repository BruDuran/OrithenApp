<Window x:Class="OrithenApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OrithenApp POC" Height="720" Width="1100"
        Background="#F8FAFC">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <Border Background="#FFFFFF" BorderBrush="#D7E2F2" BorderThickness="0,0,0,1" Padding="12">
      <StackPanel Orientation="Horizontal">
        <Button Content="Introducir datos o modificar datos" Click="OpenExercises" Margin="0,0,8,0" />
        <Button Content="Crear plantilla" Click="OpenCreateTemplate" Margin="0,0,8,0" />
        <Button Content="Visualizar" Click="OpenTemplateView" />
      </StackPanel>
    </Border>

    <Border Grid.Row="1" Margin="12" BorderBrush="#D7E2F2" BorderThickness="1" Padding="12" Background="#FFFFFF" CornerRadius="8">
      <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden" />
    </Border>
  </Grid>
</Window>
